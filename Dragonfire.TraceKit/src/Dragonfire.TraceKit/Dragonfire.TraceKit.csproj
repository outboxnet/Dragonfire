<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Dragonfire.TraceKit</RootNamespace>
    <PackageId>Dragonfire.TraceKit</PackageId>
    <Description>Non-blocking API request/response tracing for ASP.NET Core. Captures inbound API calls and every outbound HttpClient call, preserves call sequence within a request, redacts secrets, and persists via a repository abstraction so storage stays decoupled from your data model.</Description>
    <PackageTags>tracing;observability;aspnetcore;httpclient;audit;b2b;redaction;repository</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
</Project>
