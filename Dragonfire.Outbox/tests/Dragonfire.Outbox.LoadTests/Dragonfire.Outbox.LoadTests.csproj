<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Dragonfire.Outbox.LoadTests</RootNamespace>
    <!-- Not a web server — suppress launchSettings requirement -->
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>

  <ItemGroup>
    <!-- Needed for LoadTestDbContext (DbContext base class + UseSqlServer extension) -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Dragonfire.Outbox.Core\Dragonfire.Outbox.Core.csproj" />
    <ProjectReference Include="..\..\src\Dragonfire.Outbox.Delivery\Dragonfire.Outbox.Delivery.csproj" />
    <ProjectReference Include="..\..\src\Dragonfire.Outbox.EntityFrameworkCore\Dragonfire.Outbox.EntityFrameworkCore.csproj" />
    <ProjectReference Include="..\..\src\Dragonfire.Outbox.Processor\Dragonfire.Outbox.Processor.csproj" />
  </ItemGroup>

</Project>
