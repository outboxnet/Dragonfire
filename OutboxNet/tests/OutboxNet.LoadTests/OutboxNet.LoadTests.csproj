<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OutboxNet.LoadTests</RootNamespace>
    <!-- Not a web server — suppress launchSettings requirement -->
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>

  <ItemGroup>
    <!-- Needed for LoadTestDbContext (DbContext base class + UseSqlServer extension) -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\OutboxNet.Core\OutboxNet.Core.csproj" />
    <ProjectReference Include="..\..\src\OutboxNet.Delivery\OutboxNet.Delivery.csproj" />
    <ProjectReference Include="..\..\src\OutboxNet.EntityFrameworkCore\OutboxNet.EntityFrameworkCore.csproj" />
    <ProjectReference Include="..\..\src\OutboxNet.Processor\OutboxNet.Processor.csproj" />
  </ItemGroup>

</Project>
