@model SubscriptionFormModel
@{
    ViewData["Title"] = "Edit subscription";
}
<div class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900">Edit subscription</h1>
    <p class="text-sm text-slate-500 mt-1">Changes apply to future deliveries. Past delivery attempts keep their original metadata.</p>
</div>
<div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6 max-w-3xl">
    @await Html.PartialAsync("_Form", Model)
</div>
