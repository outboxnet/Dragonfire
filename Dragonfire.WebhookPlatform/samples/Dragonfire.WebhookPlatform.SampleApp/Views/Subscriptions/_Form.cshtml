@model SubscriptionFormModel
@{
    var isEdit = Model.Id is not null;
    var actionName = isEdit ? "Edit" : "Create";
}
<form asp-action="@actionName" method="post" class="space-y-4">
    @Html.AntiForgeryToken()
    @if (isEdit)
    {
        <input type="hidden" asp-for="Id" />
    }
    <div asp-validation-summary="ModelOnly" class="text-sm text-red-700"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label asp-for="Name" class="block text-xs uppercase tracking-wide text-slate-500 mb-1"></label>
            <input asp-for="Name"
                   class="w-full px-3 py-2 rounded border border-slate-300 text-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
            <span asp-validation-for="Name" class="text-xs text-red-700"></span>
        </div>
        <div>
            <label asp-for="EventType" class="block text-xs uppercase tracking-wide text-slate-500 mb-1"></label>
            <input asp-for="EventType"
                   class="w-full px-3 py-2 rounded border border-slate-300 text-sm font-mono focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
            <span asp-validation-for="EventType" class="text-xs text-red-700"></span>
        </div>
        <div class="md:col-span-2">
            <label asp-for="WebhookUrl" class="block text-xs uppercase tracking-wide text-slate-500 mb-1"></label>
            <input asp-for="WebhookUrl" type="url"
                   class="w-full px-3 py-2 rounded border border-slate-300 text-sm font-mono focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
            <span asp-validation-for="WebhookUrl" class="text-xs text-red-700"></span>
        </div>
        <div class="md:col-span-2">
            <label asp-for="Secret" class="block text-xs uppercase tracking-wide text-slate-500 mb-1"></label>
            <input asp-for="Secret"
                   class="w-full px-3 py-2 rounded border border-slate-300 text-sm font-mono focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
            <span asp-validation-for="Secret" class="text-xs text-red-700"></span>
            <p class="text-xs text-slate-500 mt-1">Used as the HMAC-SHA256 key for the <code>X-Outbox-Signature</code> header.</p>
        </div>
        <div>
            <label asp-for="TenantId" class="block text-xs uppercase tracking-wide text-slate-500 mb-1"></label>
            <input asp-for="TenantId"
                   class="w-full px-3 py-2 rounded border border-slate-300 text-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
            <span asp-validation-for="TenantId" class="text-xs text-red-700"></span>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="MaxRetries" class="block text-xs uppercase tracking-wide text-slate-500 mb-1"></label>
                <input asp-for="MaxRetries" type="number"
                       class="w-full px-3 py-2 rounded border border-slate-300 text-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
                <span asp-validation-for="MaxRetries" class="text-xs text-red-700"></span>
            </div>
            <div>
                <label asp-for="TimeoutSeconds" class="block text-xs uppercase tracking-wide text-slate-500 mb-1"></label>
                <input asp-for="TimeoutSeconds" type="number"
                       class="w-full px-3 py-2 rounded border border-slate-300 text-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
                <span asp-validation-for="TimeoutSeconds" class="text-xs text-red-700"></span>
            </div>
        </div>
        <div class="md:col-span-2 flex items-center gap-2">
            <input asp-for="IsActive" type="checkbox" class="rounded border-slate-300" />
            <label asp-for="IsActive" class="text-sm text-slate-700"></label>
        </div>
    </div>

    <div class="flex items-center gap-2 pt-2">
        <button type="submit"
                class="px-4 py-2 rounded bg-orange-600 hover:bg-orange-500 text-white text-sm font-medium">
            @(isEdit ? "Save changes" : "Create subscription")
        </button>
        <a asp-action="Index" class="px-4 py-2 rounded border border-slate-300 hover:bg-slate-50 text-sm text-slate-700">Cancel</a>
    </div>
</form>
