@{
    var path = Context.Request.Path.Value ?? "/";
    string ActiveClass(string match) =>
        path.Equals(match, StringComparison.OrdinalIgnoreCase) ||
        (match != "/" && path.StartsWith(match, StringComparison.OrdinalIgnoreCase))
            ? "bg-slate-900 text-white"
            : "text-slate-300 hover:bg-slate-800 hover:text-white";
    var toast = TempData["Toast"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Dragonfire Webhook Platform</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-slate-100 text-slate-800 antialiased">
    <div class="min-h-screen flex">
        <aside class="w-64 bg-slate-950 text-slate-100 flex-shrink-0 flex flex-col">
            <div class="px-5 py-6 border-b border-slate-800">
                <div class="flex items-center gap-2">
                    <span class="inline-block w-3 h-3 rounded-full bg-orange-500"></span>
                    <span class="font-semibold tracking-tight">Dragonfire</span>
                </div>
                <p class="text-xs text-slate-400 mt-1">Webhook Platform</p>
            </div>
            <nav class="flex-1 px-3 py-4 space-y-1 text-sm font-medium">
                <a href="/" class="block px-3 py-2 rounded @ActiveClass("/")">Overview</a>
                <a href="/Outgoing" class="block px-3 py-2 rounded @ActiveClass("/Outgoing")">Outgoing</a>
                <a href="/Incoming" class="block px-3 py-2 rounded @ActiveClass("/Incoming")">Incoming</a>
                <a href="/Subscriptions" class="block px-3 py-2 rounded @ActiveClass("/Subscriptions")">Subscriptions</a>
            </nav>
            <div class="px-5 py-4 border-t border-slate-800 text-xs text-slate-400 space-y-2">
                <p class="font-semibold text-slate-300">Generate events</p>
                <form method="post" action="/ui/generate" class="space-y-1">
                    <button type="submit"
                            class="w-full text-left px-2 py-1.5 rounded bg-orange-600 hover:bg-orange-500 text-white text-xs">
                        + Single order
                    </button>
                </form>
                <form method="post" action="/ui/burst?n=500" class="space-y-1">
                    <button type="submit"
                            class="w-full text-left px-2 py-1.5 rounded bg-slate-800 hover:bg-slate-700 text-slate-100 text-xs">
                        + Burst of 5
                    </button>
                </form>
                <p class="pt-2 leading-5">
                    Sent with <code class="text-orange-300">X-Tenant-Id: demo-tenant</code>
                    via the static fallback resolver.
                </p>
            </div>
        </aside>

        <main class="flex-1 px-8 py-8 overflow-x-hidden">
            <div class="max-w-7xl mx-auto">
                @if (!string.IsNullOrEmpty(toast))
                {
                    <div class="mb-4 rounded border border-emerald-200 bg-emerald-50 text-emerald-900 px-4 py-2 text-sm">
                        @toast
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    </div>
</body>
</html>
