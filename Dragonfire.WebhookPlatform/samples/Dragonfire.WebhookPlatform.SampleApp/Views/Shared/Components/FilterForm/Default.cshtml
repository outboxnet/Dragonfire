@model Dragonfire.WebhookPlatform.SampleApp.ViewComponents.FilterFormViewComponent.FilterFormModel
@{
    var f = Model.Filter;
}
<form method="get" class="bg-white rounded-lg shadow-sm border border-slate-200 p-4 mb-6 space-y-3">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
        <div>
            <label class="block text-xs uppercase tracking-wide text-slate-500 mb-1">Event type</label>
            <input list="known-event-types" name="EventType" value="@f.EventType"
                   placeholder="e.g. order.created"
                   class="w-full px-3 py-2 rounded border border-slate-300 text-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
            <datalist id="known-event-types">
                @foreach (var et in Model.KnownEventTypes)
                {
                    <option value="@et"></option>
                }
            </datalist>
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wide text-slate-500 mb-1">JSON path</label>
            <input name="JsonPath" value="@f.JsonPath" placeholder="$.customerId"
                   class="w-full px-3 py-2 rounded border border-slate-300 text-sm font-mono focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wide text-slate-500 mb-1">JSON value equals</label>
            <input name="JsonValue" value="@f.JsonValue" placeholder="cust-1234"
                   class="w-full px-3 py-2 rounded border border-slate-300 text-sm font-mono focus:ring-2 focus:ring-orange-500 focus:border-orange-500" />
        </div>
        <div class="flex items-end gap-2">
            <button type="submit"
                    class="flex-1 px-3 py-2 rounded bg-slate-900 hover:bg-slate-800 text-white text-sm font-medium">
                Filter
            </button>
            <a href="@Context.Request.Path"
               class="px-3 py-2 rounded border border-slate-300 hover:bg-slate-50 text-slate-700 text-sm">
                Clear
            </a>
        </div>
    </div>
    <p class="text-xs text-slate-500">
        Filters AND together. JSON path uses
        <code class="text-slate-700">JSON_VALUE(Payload, '&lt;path&gt;')</code> on SQL Server.
        Example paths: <code>$.customerId</code>, <code>$.total</code>, <code>$.lines[0].sku</code>.
    </p>
</form>
