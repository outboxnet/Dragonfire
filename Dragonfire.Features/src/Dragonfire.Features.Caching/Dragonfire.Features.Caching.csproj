<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Dragonfire.Features.Caching</RootNamespace>
    <AssemblyName>Dragonfire.Features.Caching</AssemblyName>
    <PackageId>Dragonfire.Features.Caching</PackageId>
    <Description>Dragonfire.Caching integration for Dragonfire.Features. Wraps the default IFeatureResolver in a decorator that caches per (feature, tenant, user) tuple via ICacheService, with tag-based invalidation per tenant. Decisions stay hot for high-RPS endpoints while still respecting the next refresh cycle.</Description>
    <PackageTags>feature-flags;caching;multi-tenant;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Cross-suite NuGet dependency. Pinned to $(Version) so Features.Caching
      always references the matching Dragonfire.Caching version that ships in
      the same release. CI passes -p:Version=X via root Directory.Build.props;
      NuGet then resolves either from the dragonfire-local source (./artifacts)
      during a full release run, or from nuget.org when releasing Features
      stand-alone (the matching Dragonfire.Caching must already be published).
    -->
    <PackageReference Include="Dragonfire.Caching" Version="$(Version)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dragonfire.Features\Dragonfire.Features.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
