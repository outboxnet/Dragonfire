<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Dragonfire.Features.Configuration</RootNamespace>
    <AssemblyName>Dragonfire.Features.Configuration</AssemblyName>
    <PackageId>Dragonfire.Features.Configuration</PackageId>
    <Description>IConfiguration-backed feature source for Dragonfire.Features. Reads feature definitions and rules from the standard Microsoft.Extensions.Configuration pipeline (appsettings.json, environment variables, Azure App Configuration, etc.) and reloads them on the periodic refresh cycle.</Description>
    <PackageTags>feature-flags;configuration;appsettings;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="8.0.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dragonfire.Features\Dragonfire.Features.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
