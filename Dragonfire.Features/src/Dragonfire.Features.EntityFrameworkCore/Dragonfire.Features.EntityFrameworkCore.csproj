<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Dragonfire.Features.EntityFrameworkCore</RootNamespace>
    <AssemblyName>Dragonfire.Features.EntityFrameworkCore</AssemblyName>
    <PackageId>Dragonfire.Features.EntityFrameworkCore</PackageId>
    <Description>Entity Framework Core integration for Dragonfire.Features. Persists feature definitions, rules and audit history to any EF Core provider (SQL Server, PostgreSQL, SQLite, etc.). Provides EfCoreFeatureSource and EfCoreFeatureAuditLog plus an ApplyFeatureConfigurations() ModelBuilder extension that you call from your own DbContext.</Description>
    <PackageTags>feature-flags;efcore;entity-framework;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" Version="8.0.11" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dragonfire.Features\Dragonfire.Features.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
