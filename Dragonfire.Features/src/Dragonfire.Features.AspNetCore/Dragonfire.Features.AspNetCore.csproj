<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Dragonfire.Features.AspNetCore</RootNamespace>
    <AssemblyName>Dragonfire.Features.AspNetCore</AssemblyName>
    <PackageId>Dragonfire.Features.AspNetCore</PackageId>
    <Description>ASP.NET Core integration for Dragonfire.Features: action filter and endpoint filter that honour [FeatureGate] attributes, RequireFeature() endpoint extension, and HttpContext-aware IFeatureContextAccessor that reads tenant id from a configurable header/claim and user id from the authenticated principal.</Description>
    <PackageTags>feature-flags;aspnetcore;endpoint-filter;action-filter;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dragonfire.Features\Dragonfire.Features.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
