<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Dragonfire.Features</PackageId>
    <Description>Feature toggle and release-gate library for .NET 8 — declarative [FeatureGate] attribute, per-tenant/per-user/percentage rules, pluggable IFeatureSource (configuration, EF Core, custom), in-memory store with periodic refresh, and pluggable audit log for B2B compliance. Add Dragonfire.Features.AspNetCore, Configuration, EntityFrameworkCore, or Caching for integrations.</Description>
    <PackageTags>feature-flags;feature-toggles;release-gate;rollout;multi-tenant;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.0.2" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0.2" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="8.0.2" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" Condition="Exists('../../README.md')" />
  </ItemGroup>

</Project>
