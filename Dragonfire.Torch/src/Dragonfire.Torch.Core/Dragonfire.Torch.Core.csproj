<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Dragonfire.Torch</RootNamespace>
    <AssemblyName>Dragonfire.Torch.Core</AssemblyName>
    <PackageId>Dragonfire.Torch.Core</PackageId>
    <Description>Core engine for Dragonfire.Torch — parses Postman v2.1 collections into an intermediate representation, infers C# types from JSON example bodies, promotes shared properties into base classes, and emits a typed C# HTTP client library via Scriban templates.</Description>
    <PackageTags>postman;codegen;http-client;dotnet;client-generator</PackageTags>

    <!--
      Templates are static, embedded resources controlled entirely by this
      project — no user-supplied input is ever parsed AS a template. The
      Scriban CVE advisories all describe template-injection vectors that
      require an attacker-controlled template, which is not in our threat
      model. Suppress NuGet vulnerability warnings on this dependency only.
    -->
    <NoWarn>$(NoWarn);NU1900;NU1901;NU1902;NU1903;NU1904</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Scriban" Version="5.10.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
    <EmbeddedResource Include="Templates/**/*.sbn" />
  </ItemGroup>

</Project>
