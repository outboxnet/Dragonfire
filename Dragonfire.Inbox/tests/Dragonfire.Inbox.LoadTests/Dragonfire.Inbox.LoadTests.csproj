<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Dragonfire.Inbox.LoadTests</RootNamespace>
    <IsPackable>false</IsPackable>
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Dragonfire.Inbox.Core\Dragonfire.Inbox.Core.csproj" />
    <ProjectReference Include="..\..\src\Dragonfire.Inbox.EntityFrameworkCore\Dragonfire.Inbox.EntityFrameworkCore.csproj" />
    <ProjectReference Include="..\..\src\Dragonfire.Inbox.Processor\Dragonfire.Inbox.Processor.csproj" />
    <ProjectReference Include="..\..\src\Dragonfire.Inbox.AspNetCore\Dragonfire.Inbox.AspNetCore.csproj" />
    <ProjectReference Include="..\..\src\Dragonfire.Inbox.Providers\Dragonfire.Inbox.Providers.csproj" />
  </ItemGroup>

</Project>
